{
  "name": "pruebatt/servicio-clientes-pedidos",
  "description": "Microservicio de Clientes y Pedidos (PHP 8 - Clean Architecture)",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-pdo_sqlsrv": "*",
    "vlucas/phpdotenv": "^5.6",
    "firebase/php-jwt": "^6.10",
    "monolog/monolog": "^3.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "PruebaTT\\ClientesPedidos\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PruebaTT\\ClientesPedidos\\Tests\\": "tests/"
    }
  }
}
